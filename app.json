{
  "expo": {
    "name": "Bitacora57",
    "slug": "bitacora",
    "scheme": "bitacora57",
    "version": "3.0.3",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "dark",
    "owner": "luis_g180418",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "android": {
      "package": "com.luisg0418.bitacora57",
      "versionCode": 77,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "CAMERA",
        "INTERNET",
        "POST_NOTIFICATIONS",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "READ_MEDIA_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.luisg0418.bitacora57"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "./plugins/withGoogleSignInScheme",
        {
          "iosUrlScheme": "com.googleusercontent.apps.363075260432-73vjlu0ukn1u59sjgf5dpi1mkunda880"
        }
      ],
      "expo-notifications",
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsImpl": "mapbox"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Bitácora57 recopila datos de ubicación para registrar tu ruta y jornada laboral (NOM-087), incluso cuando la app está cerrada o no se usa.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Permite acceder a tus fotos para subir documentos.",
          "savePhotosPermission": "Permite guardar reportes en tu galería.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f77a8b33-7278-4b0b-a8cf-48b03041baee"
      }
    }
  }
}
